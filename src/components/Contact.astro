---
import { Image } from "astro:assets";
import profileImg from "../assets/images/Web_IMG.jpg";

import helloSvg from "../assets/images/Hello.svg";
---

<section id="contact" class="contact-section">
    <div class="contact-bg-wrapper">
        <div class="hello-watermark" aria-hidden="true">
            <img src={helloSvg.src} alt="" />
        </div>
    </div>

    <div class="contact-container">
        <div class="contact-info">
            <div class="section-meta">
                <span class="meta-separator">/</span>
                <span class="meta-title">CONTACT</span>
            </div>

            <h2 class="contact-title desktop-only">
                DIRECT<br />LINE.
            </h2>
            <h2 class="contact-title mobile-only">
                LET'S<br />TALK.
            </h2>

            <div class="profile-wrapper">
                <div class="image-mask">
                    <Image
                        src={profileImg}
                        alt="Retrato de Banhquez con iluminación roja"
                        class="profile-img"
                        width={240}
                        height={240}
                    />
                </div>
            </div>

            <p class="availability-text">
                Currently accepting select inquiries for motion strategy and
                high-impact production.
            </p>
        </div>

        <div class="contact-form-wrapper">
            <form class="contact-form" id="contactForm">
                <div class="form-row">
                    <div class="input-group">
                        <label for="firstName">FIRST NAME</label>
                        <input
                            type="text"
                            id="firstName"
                            name="firstName"
                            placeholder="JONATHAN"
                            required
                        />
                    </div>
                    <div class="input-group">
                        <label for="lastName">LAST NAME</label>
                        <input
                            type="text"
                            id="lastName"
                            name="lastName"
                            placeholder="DOE"
                            required
                        />
                    </div>
                </div>

                <div class="form-row">
                    <div class="input-group">
                        <label for="email">EMAIL ADDRESS</label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            placeholder="CONTACT@STUDIO.COM"
                            required
                        />
                    </div>
                    <div class="input-group">
                        <label for="company">COMPANY</label>
                        <input
                            type="text"
                            id="company"
                            name="company"
                            placeholder="GLOBAL ENTITY..."
                        />
                    </div>
                </div>

                <div class="input-group full-width">
                    <label for="message">TELL ME MORE</label>
                    <textarea
                        id="message"
                        name="message"
                        rows="2"
                        placeholder="PROJECT SCOPE AND TIMELINE..."></textarea>
                </div>

                <button type="submit" class="submit-btn" id="submitBtn">
                    LET'S CREATE TOGETHER
                </button>

                <div id="formStatus" class="form-status"></div>
            </form>
        </div>
    </div>

    <footer class="site-footer">
        <div class="footer-left">© 2026 BANHQUEZ | MOTION PROVOCATEUR.</div>
        <div class="footer-right">
            <a href="https://www.linkedin.com/in/banhquez/" target="_blank"
                >LINKEDIN</a
            >
            <a href="https://x.com/banhquez" target="_blank">X</a>
            <a href="https://www.instagram.com/banhquez/" target="_blank"
                >INSTAGRAM</a
            >
        </div>
    </footer>
</section>

<style>
    .contact-section {
        background-color: #120b10;
        background-image:
            radial-gradient(
                ellipse 100% 100% at -15% 120%,
                rgba(100, 15, 15, 0.45) 0%,
                rgba(70, 10, 10, 0.15) 45%,
                transparent 72%
            ),
            radial-gradient(
                ellipse 75% 75% at 118% -18%,
                rgba(90, 15, 15, 0.35) 0%,
                rgba(60, 10, 10, 0.1) 45%,
                transparent 70%
            );
        color: var(--color-light);
        padding: 8rem 2rem 2rem 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100vw;
        box-sizing: border-box;
        position: relative;
    }

    .contact-section::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='2.5' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        opacity: 1;
        pointer-events: none;
        z-index: 20;
        mix-blend-mode: overlay;
    }

    input:-webkit-autofill,
    input:-webkit-autofill:hover,
    input:-webkit-autofill:focus,
    input:-webkit-autofill:active,
    textarea:-webkit-autofill,
    textarea:-webkit-autofill:hover,
    textarea:-webkit-autofill:focus,
    textarea:-webkit-autofill:active {
        -webkit-text-fill-color: var(--color-light) !important;
        color: var(--color-light) !important;
        caret-color: var(--color-light) !important;
        -webkit-box-shadow: 0 0 0px 1000px #120b10 inset !important;
        box-shadow: 0 0 0px 1000px #120b10 inset !important;
        transition: background-color 5000s ease-in-out 0s;
    }

    .contact-bg-wrapper {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        z-index: 0;
        pointer-events: none;
    }

    .hello-watermark {
        position: absolute;
        bottom: 8%;
        left: 50%;
        transform: translateX(-50%);
        width: 100%;
        max-width: 1400px;
        opacity: 0.4;
        mix-blend-mode: screen;
    }

    .hello-watermark img {
        width: 100%;
        height: auto;
        display: block;
    }

    .contact-container {
        width: 100%;
        max-width: 1200px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        margin-bottom: 8rem;
        position: relative;
        z-index: 10;
    }

    .section-meta {
        font-family: var(--font-mono);
        font-size: 14px;
        color: var(--color-accent);
        letter-spacing: 0.1em;
        margin-bottom: 2rem;
        display: flex;
        gap: 0.5rem;
    }

    .contact-title {
        font-family: var(--font-display);
        font-weight: 900;
        font-size: 96px;
        line-height: 0.9;
        letter-spacing: -0.03em;
        margin-bottom: 3rem;
    }

    .profile-wrapper {
        width: 240px;
        height: 240px;
        border-radius: 50%;
        border: 2px solid var(--color-accent);
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 2rem;
    }

    .image-mask {
        width: 215px;
        height: 215px;
        border-radius: 50%;
        overflow: hidden;
    }

    .profile-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 14%;
        transform: scale(1);
    }

    .availability-text {
        font-family: var(--font-body);
        font-size: 16px;
        line-height: 1.5;
        max-width: 80%;
    }

    .contact-form {
        display: flex;
        flex-direction: column;
        gap: 3rem;
        padding-top: 3rem;
    }
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }
    .input-group {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    label {
        font-family: var(--font-mono);
        font-size: 10px;
        color: var(--color-accent);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    input,
    textarea {
        background: transparent;
        border: none;
        border-bottom: 1px solid var(--color-grey);
        color: var(--color-light);
        font-family: var(--font-body);
        font-size: 20px;
        padding: 0.5rem 0;
        border-radius: 0;
        transition: border-color 0.3s ease;
    }
    input::placeholder,
    textarea::placeholder {
        color: var(--color-grey);
        opacity: 0.5;
    }
    input:focus,
    textarea:focus {
        outline: none;
        border-bottom-color: var(--color-light);
    }
    textarea {
        resize: vertical;
        min-height: 80px;
    }

    .submit-btn {
        background-color: var(--color-accent);
        color: var(--color-light);
        border: none;
        padding: 1.5rem;
        font-family: var(--font-mono);
        font-size: 14px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        transition: filter 0.2s ease;
        margin-top: 1rem;
    }
    .submit-btn:hover,
    .submit-btn:focus-visible {
        filter: brightness(1.2);
    }

    .form-status {
        font-family: var(--font-mono);
        font-size: 12px;
        letter-spacing: 0.05em;
        margin-top: 1rem;
        text-transform: uppercase;
        color: var(--color-accent);
    }

    .site-footer {
        width: 100%;
        max-width: 1200px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 2rem;
        font-family: var(--font-mono);
        font-size: 10px;
        color: var(--color-light);
        letter-spacing: 0.05em;
        position: relative;
        z-index: 10;
    }
    .footer-right {
        display: flex;
        gap: 2rem;
    }
    .footer-right a {
        color: var(--color-light);
        text-decoration: none;
        transition: color 0.2s ease;
    }
    .footer-right a:hover,
    .footer-right a:focus-visible {
        color: var(--color-accent);
    }

    /* MEDIA QUERIES MOBILE */
    @media (max-width: 768px) {
        .contact-section {
            padding: 4rem 1.5rem 2rem 1.5rem;
        }

        .contact-container {
            grid-template-columns: 1fr;
            gap: 4rem;
            margin-bottom: 4rem;
        }

        .contact-info {
            position: relative;
        }

        .contact-title {
            font-size: 72px;
            margin-bottom: 2rem;
            position: relative;
            z-index: 2;
        }

        .profile-wrapper {
            position: absolute;
            top: -7rem;
            right: -2.5rem;
            width: 315px;
            height: 315px;
            z-index: 10;
            margin-bottom: 0;
        }

        .image-mask {
            width: 285px;
            height: 285px;
        }

        .availability-text {
            max-width: 60%;
            position: relative;
            z-index: 2;
            margin-top: 3rem;
        }

        .contact-form {
            padding-top: 0;
        }
        .form-row {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
        input,
        textarea {
            font-size: 16px;
        }

        .hello-watermark {
            bottom: 10%;
        }

        .site-footer {
            flex-direction: column;
            gap: 1.5rem;
            text-align: center;
        }
        .footer-right {
            width: 100%;
            justify-content: space-around;
            gap: 0;
        }
    }
    @media (max-width: 550px) {
        .profile-wrapper {
            position: absolute;
            top: -7rem;
            right: -2.5rem;
            width: 235px;
            height: 235px;
            z-index: 10;
            margin-bottom: 0;
        }

        .image-mask {
            width: 220px;
            height: 220px;
        }
    }
</style>

<script>
    const form = document.getElementById("contactForm") as HTMLFormElement;
    const statusDiv = document.getElementById("formStatus");
    const submitBtn = document.getElementById("submitBtn") as HTMLButtonElement;

    if (form) {
        form.addEventListener("submit", async function (e) {
            e.preventDefault();

            if (submitBtn && statusDiv) {
                submitBtn.innerText = "SENDING...";
                submitBtn.disabled = true;
                statusDiv.innerText = "";
            }

            const formData = new FormData(form);

            // REEMPLAZA ESTA CADENA POR TU ACCESS KEY DE WEB3FORMS
            formData.append("access_key", "AQUÍ_VA_TU_ACCESS_KEY");

            formData.append(
                "subject",
                "Nuevo contacto desde Banhquez Portfolio",
            );

            try {
                const response = await fetch(
                    "https://api.web3forms.com/submit",
                    {
                        method: "POST",
                        body: formData,
                    },
                );

                const data = await response.json();

                if (data.success) {
                    if (statusDiv)
                        statusDiv.innerText = "MESSAGE SENT SUCCESSFULLY.";
                    if (statusDiv) statusDiv.style.color = "#4CAF50";
                    form.reset();
                } else {
                    if (statusDiv)
                        statusDiv.innerText = "SYSTEM ERROR. PLEASE TRY AGAIN.";
                    if (statusDiv)
                        statusDiv.style.color = "var(--color-accent)";
                }
            } catch (error) {
                if (statusDiv)
                    statusDiv.innerText = "NETWORK ERROR. PLEASE TRY AGAIN.";
                if (statusDiv) statusDiv.style.color = "var(--color-accent)";
            } finally {
                if (submitBtn) {
                    submitBtn.innerText = "LET'S CREATE TOGETHER";
                    submitBtn.disabled = false;
                }
            }
        });
    }
</script>
